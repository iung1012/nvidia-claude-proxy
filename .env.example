# Copy this file to .env and fill in your values

# Address to listen on (host:port)
ADDR=127.0.0.1:8089

# NVIDIA upstream API endpoint
UPSTREAM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Your NVIDIA API key
PROVIDER_API_KEY=nvapi-your-key-here

# Optional: protect this proxy with a Bearer token (leave empty to disable)
SERVER_API_KEY=

# Request timeout in seconds for non-streaming requests (default: 300)
UPSTREAM_TIMEOUT_SECONDS=300

# Max chars to log for bodies (0 = disabled, default: 4096)
LOG_BODY_MAX_CHARS=4096

# Max chars of streamed text to preview in logs (0 = disabled, default: 256)
LOG_STREAM_TEXT_PREVIEW_CHARS=256
